{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": ["assets/web/app.js", "assets/web/fab.js", "assets/web/masthead.js", "assets/web/dom-globals.d.ts"],
  "exclude": ["node_modules"]
}
