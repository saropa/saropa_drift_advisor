{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "allowImportingTsExtensions": true
  },
  "include": [
    "assets/web/index.js",
    "assets/web/app.js",
    "assets/web/dom-globals.d.ts",
    "assets/web/**/*.ts"
  ],
  "exclude": ["node_modules", "assets/web/bundle.js", "extension/**"]
}
