{
    "cSpell.words": [
        "gphone",
        "pubdev",
        "pubspec",
        "unindexed",
        "unpushed"
    ],
    "code-runner.executorMap": {
        "python": "python -u"
    },
    // TypeScript project-wide error reporting for the extension subfolder
    // Shows ALL errors in Problems panel, not just open files
    "typescript.tsserver.experimental.enableProjectDiagnostics": true,
    "saropaLints.enabled": true,
    "saropaLints.sidebar.showPackageVibrancy": true,
    "saropaLints.sidebar.showSummary": false,
    "saropaLints.sidebar.showSuggestions": true,
    "saropaLints.sidebar.showDriftAdvisor": true,
    "saropaLints.sidebar.showFileRisk": true,
    "saropaLints.sidebar.showSecurityPosture": true,
    "saropaLints.sidebar.showRulePacks": true
}