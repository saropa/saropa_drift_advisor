{
  "version": "2.0.0",
  "tasks": [
    {
      // Compile the VS Code extension TypeScript before launching the
      // Extension Development Host. Runs `npm run compile` (which is
      // `tsc -p ./`) inside the extension/ subfolder.
      "label": "compile-extension",
      "type": "shell",
      "command": "npm",
      "args": ["run", "compile"],
      "options": { "cwd": "${workspaceFolder}/extension" },
      "group": "build",
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "Open Saropa Drift Advisor",
      "type": "shell",
      "command": "start",
      "args": ["http://127.0.0.1:8642"],
      "windows": { "command": "start", "args": ["http://127.0.0.1:8642"] },
      "osx": { "command": "open", "args": ["http://127.0.0.1:8642"] },
      "linux": { "command": "xdg-open", "args": ["http://127.0.0.1:8642"] },
      "presentation": { "reveal": "silent", "panel": "shared" }
    }
  ]
}
